<clickhouse>
    <http_handlers>
        <defaults/>
        <rule>
            <url>/metrics</url>
            <methods>GET</methods>
            <handler>
                <type>prometheus</type>
                <metrics>true</metrics>
                <events>true</events>
                <asynchronous_metrics>true</asynchronous_metrics>
            </handler>
        </rule>
    </http_handlers>
</clickhouse>
